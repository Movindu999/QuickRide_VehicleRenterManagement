    <style name="TextAppearance.QuickRide.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_secondary_light</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    <style name="TextAppearance.QuickRide.Headline" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/text_primary_light</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="TextAppearance.QuickRide.RoleTitle" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/text_primary_light</item>
        <item name="android:textSize">32sp</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="Theme.MyApplication" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        
        <item name="colorPrimary">@color/brand_blue_600</item>
        <item name="colorPrimaryVariant">@color/brand_blue_700</item>
        <item name="colorOnPrimary">@color/text_on_brand</item>

        
        <item name="colorSecondary">@color/brand_blue_500</item>
        <item name="colorSecondaryVariant">@color/brand_blue_600</item>
        <item name="colorOnSecondary">@color/text_on_brand</item>

        <item name="colorSurface">@color/surface_light</item>
        <item name="colorOnSurface">@color/text_primary_light</item>
        <item name="android:windowBackground">@color/surface_light_alt</item>
        <item name="android:textColorPrimary">@color/text_primary_light</item>

        
        <item name="android:statusBarColor">@color/brand_blue_700</item>
        <item name="android:navigationBarColor">@color/surface_light</item>

        <item name="materialButtonStyle">@style/Widget.QuickRide.Button.Primary</item>
        <item name="materialCardViewStyle">@style/Widget.QuickRide.Card</item>
        
    </style>
    <style name="Widget.MaterialComponents.AppBarLayoutPrimary" parent="Widget.QuickRide.TopAppBar"/>
    <style name="Widget.QuickRide.BottomNavigation" parent="Widget.MaterialComponents.BottomNavigationView.Colored">
        <item name="android:background">@color/surface_light_raised</item>
        <item name="itemIconTint">@color/nav_item_color</item>
        <item name="itemTextColor">@color/nav_item_color</item>
        <item name="elevation">8dp</item>
    </style>
    <style name="Widget.QuickRide.Button.Danger" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_on_brand</item>
        <item name="backgroundTint">#C0392B</item>
        <item name="rippleColor">#E74C3C</item>
        <item name="cornerRadius">12dp</item>
    </style>
    <style name="Widget.QuickRide.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">52dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_on_brand</item>
        <item name="backgroundTint">@color/brand_blue_600</item>
        <item name="rippleColor">@color/brand_blue_300</item>
        <item name="cornerRadius">14dp</item>
        <item name="elevation">2dp</item>
    </style>
    <style name="Widget.QuickRide.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/brand_blue_600</item>
        <item name="strokeColor">@color/brand_blue_600</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="rippleColor">@color/brand_blue_100</item>
        <item name="cornerRadius">12dp</item>
    </style>
    <style name="Widget.QuickRide.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface_light_raised</item>
        <item name="strokeColor">@color/border_light</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
    </style>
    <style name="Widget.QuickRide.RoleButton" parent="Widget.QuickRide.Button.Primary">
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:minHeight">56dp</item>
    </style>
    <style name="Widget.QuickRide.TopAppBar" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">@color/brand_blue_600</item>
        <item name="titleTextColor">@color/text_on_brand</item>
        <item name="subtitleTextColor">@color/text_on_brand</item>
        <item name="navigationIconTint">@color/text_on_brand</item>
    </style>
