<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:endColor="@color/brand_blue_700"
                android:startColor="@color/brand_blue_600" />
            <corners android:radius="14dp" />
            <stroke
                android:width="1dp"
                android:color="@color/brand_blue_700" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:endColor="@color/brand_blue_600"
                android:startColor="@color/brand_blue_500" />
            <corners android:radius="14dp" />
            <stroke
                android:width="1dp"
                android:color="@color/brand_blue_700" />
        </shape>
    </item>
</selector>
