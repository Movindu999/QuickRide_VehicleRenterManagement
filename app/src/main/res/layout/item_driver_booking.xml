<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.QuickRide.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Booking Number -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                style="@style/TextAppearance.QuickRide.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_booking_number"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtBookingNumber"
                style="@style/TextAppearance.QuickRide.Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#BK12345"
                android:textColor="@color/text_primary_light" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:background="@color/border_light" />

        <!-- Customer ID -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                style="@style/TextAppearance.QuickRide.Body"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="@string/label_customer_id"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtCustomerId"
                style="@style/TextAppearance.QuickRide.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="CUST001"
                android:textColor="@color/text_primary_light" />
        </LinearLayout>

        <!-- Vehicle Type -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                style="@style/TextAppearance.QuickRide.Body"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="@string/label_vehicle_type"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtVehicleType"
                style="@style/TextAppearance.QuickRide.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Car"
                android:textColor="@color/text_primary_light" />
        </LinearLayout>

        <!-- Start Date -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                style="@style/TextAppearance.QuickRide.Body"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="@string/label_start_date"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtStartDate"
                style="@style/TextAppearance.QuickRide.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2024-01-15"
                android:textColor="@color/text_primary_light" />
        </LinearLayout>

        <!-- End Date -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                style="@style/TextAppearance.QuickRide.Body"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="@string/label_end_date"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtEndDate"
                style="@style/TextAppearance.QuickRide.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2024-01-20"
                android:textColor="@color/text_primary_light" />
        </LinearLayout>

        <!-- Cancel Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelBooking"
            style="@style/Widget.QuickRide.Button.Danger"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_cancel_booking" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

