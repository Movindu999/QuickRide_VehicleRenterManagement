<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_surface">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <include layout="@layout/include_top_app_bar" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="76dp"
        android:clipToPadding="false"
        android:padding="16dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtAdminTitle"
                style="@style/TextAppearance.QuickRide.Headline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/screen_admin_dashboard" />

            <TextView
                style="@style/TextAppearance.QuickRide.Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/welcome_admin" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.QuickRide.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnManageRenters"
                        style="@style/Widget.QuickRide.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/screen_manage_renters" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnManageCustomers"
                        style="@style/Widget.QuickRide.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/screen_manage_customers" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnManageBookings"
                        style="@style/Widget.QuickRide.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/screen_manage_bookings" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnViewComplaints"
                        style="@style/Widget.QuickRide.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/screen_view_complaints" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <include layout="@layout/include_bottom_nav_admin" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
